FROM python:3.13-slim
WORKDIR /app
COPY shared ./shared
COPY gateway ./gateway
ENV PYTHONPATH=/app
RUN pip install --no-cache-dir fastapi uvicorn[standard] httpx structlog python-jose[cryptography] prometheus-client pydantic-settings aiokafka
EXPOSE 8080
CMD ["uvicorn", "gateway.main:app", "--host", "0.0.0.0", "--port", "8080"]

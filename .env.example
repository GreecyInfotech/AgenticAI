# Application
APP_ENV=development
APP_NAME=ai-distributor-ordering-platform
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000

# LLM
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://localhost:11434
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=distributor
POSTGRES_PASSWORD=distributor_secret
POSTGRES_DB=distributor_platform

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=distributor_knowledge

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_ENABLED=true
KAFKA_CONSUMER_GROUP=ai-platform
KAFKA_AUTO_CREATE_TOPICS=true

# Email (SMTP)
EMAIL_ENABLED=true
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@distributor.local
SMTP_USE_TLS=true

# CRM
CRM_PROVIDER=mock
CRM_BASE_URL=
CRM_API_KEY=
CRM_TIMEOUT_SECONDS=10.0

# Redis advanced
REDIS_PASSWORD=
REDIS_DB=0
REDIS_SSL=false

# Postgres advanced
POSTGRES_MIN_POOL=2
POSTGRES_MAX_POOL=10
POSTGRES_SSL=false

# Qdrant advanced
QDRANT_API_KEY=
QDRANT_HTTPS=false
QDRANT_ENABLED=true

# Security
JWT_SECRET=change-me-in-production-use-64-char-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Observability
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
PROMETHEUS_PORT=9090

# Gateway upstream URLs (local development)
AI_PLATFORM_URL=http://localhost:8000
ORDER_SERVICE_URL=http://localhost:8001
INVENTORY_SERVICE_URL=http://localhost:8002
CUSTOMER_SERVICE_URL=http://localhost:8003

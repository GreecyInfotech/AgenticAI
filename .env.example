# Application
APP_ENV=development
APP_NAME=ai-distributor-ordering-platform
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000

# LLM
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://localhost:11434
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=distributor
POSTGRES_PASSWORD=distributor_secret
POSTGRES_DB=distributor_platform

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=distributor_knowledge

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_ENABLED=true

# Security
JWT_SECRET=change-me-in-production-use-64-char-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Observability
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
PROMETHEUS_PORT=9090

# Gateway upstream URLs (local development)
AI_PLATFORM_URL=http://localhost:8000
ORDER_SERVICE_URL=http://localhost:8001
INVENTORY_SERVICE_URL=http://localhost:8002
CUSTOMER_SERVICE_URL=http://localhost:8003

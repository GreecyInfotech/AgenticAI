# EAAP Platform
APP_ENV=development
LOG_LEVEL=INFO

# Gateways
API_GATEWAY_URL=http://localhost:8000
AGENT_GATEWAY_URL=http://localhost:8001
RAG_SERVICE_URL=http://localhost:8002

# Data
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/eaap
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_AGENT_EVENTS_TOPIC=agent-events
KAFKA_ORDER_EVENTS_TOPIC=order-events

# Vector store
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=eaap_knowledge
FILESYSTEM_MCP_ROOT=./data/files

# Integrations
JIRA_URL=https://your-org.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=
GITHUB_TOKEN=
GITHUB_ORG=your-org

# AI
GEMINI_MODEL=gemini-2.0-flash
USE_VERTEX_AI=false

# Observability
OTEL_EXPORTER_ENDPOINT=http://localhost:4318
PROMETHEUS_PORT=9090

# Frontend
VITE_API_URL=http://localhost:8000
